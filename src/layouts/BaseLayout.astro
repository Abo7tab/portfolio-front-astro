---
import SEO from '../components/SEO.astro';
import Analytics from '@vercel/analytics/astro';

/* ── Astro CSS imports: these get bundled and injected correctly ── */
import '../styles/global.css';
import '../styles/animated-bg.css';
import '../styles/skeleton.css';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Mohamed Emad Ali | Portfolio',
  description = 'Mohamed Emad Ali (محمد عماد علي) - DevOps & Network Engineer and Freelance Web Developer based in Giza, Egypt. Portfolio showcasing projects, skills, and certificates.',
  lang = 'en',
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang} dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- SEO Component -->
  <SEO title={title} description={description} />

  <!-- Preconnect for performance -->
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- API Preload for LCP Optimization -->
  <link rel="preload" href="https://folio.alwaysdata.net/api/profile" as="fetch" crossorigin="anonymous" />
  
  <script is:inline>
    // Extremely fast inline fetch to preload the LCP image as soon as HTML is parsed
    (async function() {
      try {
        const res = await fetch('https://folio.alwaysdata.net/api/profile');
        if (res.ok) {
          const json = await res.json();
          if (json.data && json.data.profile_image) {
            const imgUrl = json.data.profile_image.startsWith('http') 
              ? json.data.profile_image 
              : 'https://folio.alwaysdata.net' + json.data.profile_image;
            const link = document.createElement('link');
            link.rel = 'preload';
            link.as = 'image';
            link.href = imgUrl;
            link.fetchPriority = 'high';
            document.head.appendChild(link);
          }
        }
      } catch (e) {}
    })();
  </script>

  <!-- Google Fonts — Poppins & JetBrains Mono (Deferred for Performance) -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" media="print" onload="this.media='all'" />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" />
  </noscript>

  <!-- Remix Icon CDN (Deferred for Performance) -->
  <link rel="preload" as="style" href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" /></noscript>

  <!-- Bootstrap 5.3 CSS (Deferred to fix Render Blocking and FCP) -->
  <link rel="preload" as="style" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" /></noscript>

  <!-- FOUC Prevention: Apply cached theme color synchronously BEFORE paint -->
  <script is:inline>
    (function () {
      var cachedHex = localStorage.getItem('theme_accent');
      var cachedBgHex = localStorage.getItem('theme_bg_accent') || '#031B28';
      var s = document.documentElement.style;
      s.setProperty('--bg-accent', cachedBgHex);
      if (cachedHex) {
        var result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(cachedHex);
        if (result) {
          var r = parseInt(result[1], 16);
          var g = parseInt(result[2], 16);
          var b = parseInt(result[3], 16);
          s.setProperty('--accent', cachedHex);
          s.setProperty('--accent-glow', 'rgba('+r+','+g+','+b+',0.4)');
          s.setProperty('--accent-glow-01', 'rgba('+r+','+g+','+b+',0.1)');
          s.setProperty('--accent-glow-012', 'rgba('+r+','+g+','+b+',0.12)');
          s.setProperty('--accent-glow-02', 'rgba('+r+','+g+','+b+',0.2)');
          s.setProperty('--accent-glow-03', 'rgba('+r+','+g+','+b+',0.3)');
          s.setProperty('--accent-glow-04', 'rgba('+r+','+g+','+b+',0.4)');
          s.setProperty('--accent-glow-045', 'rgba('+r+','+g+','+b+',0.45)');
          s.setProperty('--accent-glow-05', 'rgba('+r+','+g+','+b+',0.5)');
          s.setProperty('--accent-glow-08', 'rgba('+r+','+g+','+b+',0.8)');
          s.setProperty('--glass-border', 'rgba('+r+','+g+','+b+',0.2)');
        }
      }
    })();
  </script>
</head>

<body>
  <slot />
  
  <Analytics />

  <!-- Bootstrap 5.3 JS Bundle (includes Popper) -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" defer></script>
</body>
</html>
